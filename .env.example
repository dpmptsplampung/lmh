# Deployment identity
APP_ENV=development
APP_VERSION=local-development

# Core Supabase. Replace every clearly marked value before staging/production.
NEXT_PUBLIC_SUPABASE_URL=https://replace-with-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# I5: Notifikasi
RESEND_API_KEY=replace-with-resend-api-key
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-the-same-vapid-public-key
# Secret to protect internal cron endpoints (/api/notif/send, /api/notif/retry).
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=replace-with-random-cron-secret
# From address for all outgoing email (Resend). Must be a verified domain.
RESEND_FROM=DPMPTSP Lampung <noreply@lmh.lampungprov.go.id>
# Public base URL used inside notification bodies (e.g. SKM survey link).
# Also settable per-request via DB setting app.public_url.
NEXT_PUBLIC_PUBLIC_URL=https://lmh.lampungprov.go.id
# I4: Asisten AI RAG
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Development-only escape hatch. Never set to "set" in staging/production.
LMH_DEV_RETURN_LINK=disabled
