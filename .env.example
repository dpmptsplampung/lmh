# I5: Notifikasi
RESEND_API_KEY=re_...
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
# Secret to protect internal cron endpoints (/api/notif/send, /api/notif/retry).
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=...
# From address for all outgoing email (Resend). Must be a verified domain.
RESEND_FROM=DPMPTSP Lampung <noreply@lmh.lampungprov.go.id>
# Public base URL used inside notification bodies (e.g. SKM survey link).
# Also settable per-request via DB setting app.public_url.
NEXT_PUBLIC_PUBLIC_URL=https://lmh.lampungprov.go.id
# I4: Asisten AI RAG
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
